<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ======================== COLOR PALETTE ======================== -->
    <SolidColorBrush x:Key="ClaudeBg"          Color="#F5F0E8" />
    <SolidColorBrush x:Key="ClaudeBgLight"     Color="#FAF8F4" />
    <SolidColorBrush x:Key="ClaudeDark"        Color="#2C2521" />
    <SolidColorBrush x:Key="ClaudeAccent"      Color="#D97757" />
    <SolidColorBrush x:Key="ClaudeAccentHover" Color="#C4693F" />
    <SolidColorBrush x:Key="ClaudeAccentLight" Color="#E8A88A" />
    <SolidColorBrush x:Key="ClaudeBorder"      Color="#E0D8CC" />
    <SolidColorBrush x:Key="ClaudeText"        Color="#2C2521" />
    <SolidColorBrush x:Key="ClaudeTextDim"     Color="#7A7067" />
    <SolidColorBrush x:Key="ClaudeSuccess"     Color="#5A8F5A" />
    <SolidColorBrush x:Key="ClaudeError"       Color="#C45454" />
    <SolidColorBrush x:Key="ClaudeWarning"     Color="#D4A843" />
    <SolidColorBrush x:Key="ClaudeWhite"       Color="#FFFFFF" />

    <!-- ======================== BUTTON STYLES ======================== -->

    <!-- Primary Button -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background"    Value="{StaticResource ClaudeAccent}" />
        <Setter Property="Foreground"    Value="{StaticResource ClaudeWhite}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"       Value="12,6" />
        <Setter Property="Cursor"        Value="Hand" />
        <Setter Property="FontSize"      Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource ClaudeAccentHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#A85A35" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#B0A89E" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary Button -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Foreground"      Value="{StaticResource ClaudeAccent}" />
        <Setter Property="BorderBrush"     Value="{StaticResource ClaudeAccent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"         Value="12,6" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="FontSize"        Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource ClaudeAccentLight}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource ClaudeAccent}" />
                            <Setter Property="Foreground" Value="{StaticResource ClaudeWhite}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger Button -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Background"    Value="{StaticResource ClaudeError}" />
        <Setter Property="Foreground"    Value="{StaticResource ClaudeWhite}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"       Value="12,6" />
        <Setter Property="Cursor"        Value="Hand" />
        <Setter Property="FontSize"      Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#A84444" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#8C3838" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#B0A89E" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======================== CARD / CONTAINER STYLES ======================== -->

    <!-- Card Border -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background"   Value="{StaticResource ClaudeWhite}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderBrush"  Value="{StaticResource ClaudeBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"      Value="16" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8"
                                  ShadowDepth="2"
                                  Opacity="0.15"
                                  Color="#000000" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======================== INPUT STYLES ======================== -->

    <!-- TextBox -->
    <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background"      Value="{StaticResource ClaudeWhite}" />
        <Setter Property="BorderBrush"     Value="{StaticResource ClaudeBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"         Value="8,4" />
        <Setter Property="FontSize"        Value="13" />
        <Setter Property="Foreground"      Value="{StaticResource ClaudeText}" />
        <Setter Property="CaretBrush"      Value="{StaticResource ClaudeAccent}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch"
                                      Focusable="False" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ClaudeAccent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ClaudeAccentLight}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======================== STATUS BADGES ======================== -->

    <!-- Installed Badge -->
    <Style x:Key="StatusBadgeInstalled" TargetType="Border">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background"   Value="#E8F5E9" />
        <Setter Property="Padding"      Value="8,2" />
        <Setter Property="Child">
            <Setter.Value>
                <TextBlock Text="Installed"
                           Foreground="{StaticResource ClaudeSuccess}"
                           FontSize="11"
                           FontWeight="SemiBold" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Not Installed Badge -->
    <Style x:Key="StatusBadgeNotInstalled" TargetType="Border">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background"   Value="#F5F5F5" />
        <Setter Property="Padding"      Value="8,2" />
        <Setter Property="Child">
            <Setter.Value>
                <TextBlock Text="Not Installed"
                           Foreground="{StaticResource ClaudeTextDim}"
                           FontSize="11"
                           FontWeight="SemiBold" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======================== TEXTBLOCK HEADINGS ======================== -->

    <!-- H1 -->
    <Style x:Key="Heading1" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource ClaudeText}" />
        <Setter Property="Margin"     Value="0,0,0,4" />
    </Style>

    <!-- H2 -->
    <Style x:Key="Heading2" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ClaudeText}" />
        <Setter Property="Margin"     Value="0,0,0,4" />
    </Style>

    <!-- H3 -->
    <Style x:Key="Heading3" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ClaudeText}" />
        <Setter Property="Margin"     Value="0,0,0,2" />
    </Style>

    <!-- Caption / Dim text -->
    <Style x:Key="CaptionText" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="11" />
        <Setter Property="Foreground" Value="{StaticResource ClaudeTextDim}" />
    </Style>

    <!-- ======================== SCROLLBAR STYLES ======================== -->

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="4"
                                                    Background="{StaticResource ClaudeBorder}"
                                                    Margin="1" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======================== TOOLTIP ======================== -->

    <Style TargetType="ToolTip">
        <Setter Property="Background"   Value="{StaticResource ClaudeDark}" />
        <Setter Property="Foreground"   Value="{StaticResource ClaudeWhite}" />
        <Setter Property="Padding"      Value="8,4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>