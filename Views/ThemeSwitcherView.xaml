<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Theme List -->
        <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search Box -->
                <TextBox x:Name="SearchTheme"
                         Grid.Row="0"
                         FontSize="13"
                         Padding="8"
                         Margin="0,0,0,8"/>

                <!-- Theme List -->
                <ListBox x:Name="ThemeList"
                         Grid.Row="1"
                         FontSize="13"/>
            </Grid>
        </Border>

        <!-- Right Panel: Preview -->
        <StackPanel Grid.Column="1">
            <TextBlock x:Name="ThemeName"
                       Text="选择一个主题"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#2C2521"
                       Margin="0,0,0,12"/>

            <Border Background="#FFFFFF"
                    CornerRadius="8"
                    BorderBrush="#E0D8CC"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Canvas x:Name="ThemePreviewCanvas"
                        Width="500"
                        Height="280"
                        HorizontalAlignment="Left"/>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button x:Name="BtnApplyTheme"
                        Content="应用主题"
                        Background="#D97757"
                        Foreground="White"
                        Padding="24,8"
                        BorderThickness="0"/>

                <Button x:Name="BtnRevertTheme"
                        Content="恢复"
                        Background="#E0D8CC"
                        Foreground="#2C2521"
                        Padding="16,8"
                        BorderThickness="0"
                        Margin="12,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
