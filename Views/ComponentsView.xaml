<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F0E8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Component List -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ComponentList" Margin="0,0,0,8">

                <!-- Oh My Posh -->
                <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="ChkOhMyPosh" Grid.Column="0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Oh My Posh" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                            <TextBlock Text="PowerShell 提示符主题引擎" FontSize="12" Foreground="#7A7067" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <Border x:Name="BadgeOhMyPosh" CornerRadius="10" Padding="10,3" Background="#F5F5F5">
                                <TextBlock x:Name="BadgeTextOhMyPosh" Text="未安装" FontSize="11" Foreground="#7A7067"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Nerd Font -->
                <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="ChkNerdFont" Grid.Column="0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Nerd Font" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                            <TextBlock Text="带图标和连字的等宽字体" FontSize="12" Foreground="#7A7067" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <Border x:Name="BadgeNerdFont" CornerRadius="10" Padding="10,3" Background="#F5F5F5">
                                <TextBlock x:Name="BadgeTextNerdFont" Text="未安装" FontSize="11" Foreground="#7A7067"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Windows Terminal -->
                <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="ChkWinTerminal" Grid.Column="0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Windows Terminal" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                            <TextBlock Text="现代终端，支持标签页和多配置" FontSize="12" Foreground="#7A7067" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <Border x:Name="BadgeWinTerminal" CornerRadius="10" Padding="10,3" Background="#F5F5F5">
                                <TextBlock x:Name="BadgeTextWinTerminal" Text="未安装" FontSize="11" Foreground="#7A7067"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 终端配置 -->
                <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="ChkWTConfig" Grid.Column="0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="终端配置" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                            <TextBlock Text="Tokyo Night 配色 + 亚克力透明" FontSize="12" Foreground="#7A7067" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <Border x:Name="BadgeWTConfig" CornerRadius="10" Padding="10,3" Background="#F5F5F5">
                                <TextBlock x:Name="BadgeTextWTConfig" Text="未安装" FontSize="11" Foreground="#7A7067"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- PowerShell 配置 -->
                <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="ChkPSProfile" Grid.Column="0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="PowerShell 配置" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                            <TextBlock Text="Oh My Posh 主题 + PSReadLine 增强" FontSize="12" Foreground="#7A7067" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <Border x:Name="BadgePSProfile" CornerRadius="10" Padding="10,3" Background="#F5F5F5">
                                <TextBlock x:Name="BadgeTextPSProfile" Text="未安装" FontSize="11" Foreground="#7A7067"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 状态栏 -->
                <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="ChkStatusLine" Grid.Column="0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="状态栏" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                            <TextBlock Text="Claude Code 上下文与 Token 监控" FontSize="12" Foreground="#7A7067" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <Border x:Name="BadgeStatusLine" CornerRadius="10" Padding="10,3" Background="#F5F5F5">
                                <TextBlock x:Name="BadgeTextStatusLine" Text="未安装" FontSize="11" Foreground="#7A7067"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Row 1: Bottom Action Bar -->
        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="8" Padding="16" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="SelectionSummary" Text="已选择 0 项" FontSize="13" Foreground="#7A7067" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnSelectAll" Content="全选" Padding="16,6" BorderThickness="0" FontSize="12"
                            Background="#E0D8CC" Foreground="#2C2521" Margin="0,0,8,0"/>
                    <Button x:Name="BtnApply" Content="应用更改" Padding="24,6" BorderThickness="0" FontSize="13"
                            Background="#D97757" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
