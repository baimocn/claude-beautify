<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude 终端美化"
        Width="960" Height="640"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===================== LEFT SIDEBAR ===================== -->
        <Border Grid.Column="0" Background="#2C2521">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: Custom Title Bar -->
                <Grid x:Name="TitleBar" Grid.Row="0" Height="48" Cursor="Hand">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Claude 终端美化"
                               FontSize="13"
                               Foreground="#C0B8AE"
                               Margin="20,14,0,0"
                               FontWeight="SemiBold" />

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                Margin="0,8,8,0"
                                Orientation="Horizontal">
                        <Button x:Name="BtnMinimize"
                                Content="&#xE921;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="#7A7067"
                                Width="36" Height="32"
                                Background="Transparent"
                                BorderThickness="0" />
                        <Button x:Name="BtnClose"
                                Content="&#xE8BB;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="#7A7067"
                                Width="36" Height="32"
                                Background="Transparent"
                                BorderThickness="0" />
                    </StackPanel>
                </Grid>

                <!-- Row 1: Navigation Buttons -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">

                    <!-- Dashboard (default active) -->
                    <Button x:Name="NavDashboard"
                            Height="42"
                            Margin="8,1"
                            Cursor="Hand"
                            Background="#D97757"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0">
                            <TextBlock Text="&#xE80F;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"
                                       Width="28" />
                            <TextBlock Text="仪表盘"
                                       FontSize="13"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Components -->
                    <Button x:Name="NavComponents"
                            Height="42"
                            Margin="8,1"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0">
                            <TextBlock Text="&#xE74D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Foreground="#9E9589"
                                       VerticalAlignment="Center"
                                       Width="28" />
                            <TextBlock Text="组件管理"
                                       FontSize="13"
                                       Foreground="#C0B8AE"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Themes -->
                    <Button x:Name="NavThemes"
                            Height="42"
                            Margin="8,1"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0">
                            <TextBlock Text="&#xE790;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Foreground="#9E9589"
                                       VerticalAlignment="Center"
                                       Width="28" />
                            <TextBlock Text="主题切换"
                                       FontSize="13"
                                       Foreground="#C0B8AE"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Settings -->
                    <Button x:Name="NavConfig"
                            Height="42"
                            Margin="8,1"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Foreground="#9E9589"
                                       VerticalAlignment="Center"
                                       Width="28" />
                            <TextBlock Text="设置"
                                       FontSize="13"
                                       Foreground="#C0B8AE"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Profiles -->
                    <Button x:Name="NavProfiles"
                            Height="42"
                            Margin="8,1"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Foreground="#9E9589"
                                       VerticalAlignment="Center"
                                       Width="28" />
                            <TextBlock Text="配置方案"
                                       FontSize="13"
                                       Foreground="#C0B8AE"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Profile Diff -->
                    <Button x:Name="NavProfileDiff"
                            Height="42"
                            Margin="8,1"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0">
                            <TextBlock Text="&#xE74C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Foreground="#9E9589"
                                       VerticalAlignment="Center"
                                       Width="28" />
                            <TextBlock Text="方案对比"
                                       FontSize="13"
                                       Foreground="#C0B8AE"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Row 2: Footer -->
                <StackPanel Grid.Row="2"
                            VerticalAlignment="Bottom"
                            Margin="16,0,0,16">
                    <TextBlock Text="v1.0.0"
                               Foreground="#9E9589"
                               FontSize="11"
                               HorizontalAlignment="Center" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- ===================== RIGHT CONTENT ===================== -->
        <Border Grid.Column="1"
                Background="#F5F0E8"
                CornerRadius="8"
                Margin="4,4,4,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header Area -->
                <TextBlock x:Name="PageTitle"
                           Grid.Row="0"
                           Text="Dashboard"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#2C2521"
                           Margin="24,16,0,0" />

                <!-- Content Area -->
                <ContentControl x:Name="MainContent"
                                Grid.Row="1"
                                Margin="24,8,24,24" />

            </Grid>
        </Border>

    </Grid>
</Window>
