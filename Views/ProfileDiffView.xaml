<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F0E8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Selection bar -->
        <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Profile A selector -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="方案 A" FontSize="12" FontWeight="SemiBold" Foreground="#2C2521" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ComboProfileA" Height="30" Background="#F9F6F2" BorderBrush="#E0D8CC"/>
                </StackPanel>

                <!-- VS label -->
                <TextBlock Grid.Column="1" Text="VS" FontSize="14" FontWeight="Bold" Foreground="#D97757" VerticalAlignment="Bottom" Margin="0,0,0,6"/>

                <!-- Profile B selector -->
                <StackPanel Grid.Column="3">
                    <TextBlock Text="方案 B" FontSize="12" FontWeight="SemiBold" Foreground="#2C2521" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ComboProfileB" Height="30" Background="#F9F6F2" BorderBrush="#E0D8CC"/>
                </StackPanel>

                <!-- Compare button -->
                <Button x:Name="BtnCompare" Grid.Column="4" Content="对比"
                        Background="#D97757" Foreground="White" Padding="20,7" BorderThickness="0"
                        VerticalAlignment="Bottom" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- Row 1: Summary bar -->
        <Border x:Name="DiffSummaryBar" Grid.Row="1" Background="#FFFFFF" CornerRadius="8"
                Padding="12,10" Margin="0,0,0,12" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="DiffSummaryText" Text="" FontSize="12" Foreground="#2C2521" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                    <Border Background="#FFEBEE" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                        <TextBlock x:Name="DiffCountDifferent" Text="0 项不同" FontSize="11" Foreground="#C45454"/>
                    </Border>
                    <Border Background="#E8F5E9" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                        <TextBlock x:Name="DiffCountSame" Text="0 项相同" FontSize="11" Foreground="#5A8F5A"/>
                    </Border>
                    <Border Background="#FFF8E1" CornerRadius="4" Padding="8,3">
                        <TextBlock x:Name="DiffCountOnly" Text="0 项独有" FontSize="11" Foreground="#D97757"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 2: Diff table -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      x:Name="DiffScrollViewer">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table header -->
                <Grid Grid.Row="0" Background="#ECE5DB">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Padding="12,8" BorderBrush="#D4CABD" BorderThickness="0,0,1,0">
                        <TextBlock Text="配置项" FontWeight="SemiBold" FontSize="12" Foreground="#2C2521"/>
                    </Border>
                    <Border Grid.Column="1" Padding="12,8" BorderBrush="#D4CABD" BorderThickness="0,0,1,0">
                        <TextBlock x:Name="HeaderA" Text="方案 A" FontWeight="SemiBold" FontSize="12" Foreground="#6B7AC4"/>
                    </Border>
                    <Border Grid.Column="2" Padding="12,8">
                        <TextBlock x:Name="HeaderB" Text="方案 B" FontWeight="SemiBold" FontSize="12" Foreground="#C45454"/>
                    </Border>
                </Grid>

                <!-- Diff rows container -->
                <StackPanel x:Name="DiffRowsPanel" Grid.Row="1"/>
            </Grid>
        </ScrollViewer>

        <!-- Row 3: Action bar -->
        <Border x:Name="DiffActionBar" Grid.Row="3" Background="#FFFFFF" CornerRadius="8"
                Padding="16,12" Margin="0,12,0,0" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="合并为新方案：" FontSize="12" Foreground="#2C2521" VerticalAlignment="Center">
                    <Run Text="新方案名称："/>
                    <Run Text=""/>
                </TextBlock>

                <TextBox x:Name="TxtNewName" Grid.Column="1" Width="180" Height="30"
                         Background="#F9F6F2" BorderBrush="#E0D8CC" Padding="8,4"
                         VerticalContentAlignment="Center" FontSize="12"
                         Text="merged_profile"/>

                <Button x:Name="BtnMergeA" Grid.Column="2" Content="以 A 为准合并"
                        Background="#6B7AC4" Foreground="White" Padding="14,7" BorderThickness="0"
                        Margin="12,0,0,0"/>

                <Button x:Name="BtnMergeB" Grid.Column="3" Content="以 B 为准合并"
                        Background="#C45454" Foreground="White" Padding="14,7" BorderThickness="0"
                        Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- Empty state -->
        <Border x:Name="DiffEmptyState" Grid.Row="2" Grid.RowSpan="1"
                Background="Transparent" Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                           Foreground="#D4CABD" HorizontalAlignment="Center"/>
                <TextBlock Text="选择两个方案并点击对比"
                           FontSize="14" Foreground="#9E9589"
                           Margin="0,12,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
