<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Settings Form -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,12">

                <!-- Section 1: 外观 -->
                <TextBlock Text="外观" FontSize="16" FontWeight="SemiBold" Foreground="#2C2521" Margin="0,0,0,12"/>

                <!-- 不透明度 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="不透明度" FontSize="13" Foreground="#7A7067" VerticalAlignment="Center"/>
                    <Slider x:Name="SliderOpacity" Grid.Column="1" Minimum="0" Maximum="100" Value="85" TickFrequency="10" IsSnapToTickEnabled="False" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TextOpacity" Grid.Column="2" Text="85" FontSize="12" Foreground="#7A7067" VerticalAlignment="Center"/>
                </Grid>

                <!-- 字体大小 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="字体大小" FontSize="13" Foreground="#7A7067" VerticalAlignment="Center"/>
                    <Slider x:Name="SliderFontSize" Grid.Column="1" Minimum="8" Maximum="24" Value="12" TickFrequency="1" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TextFontSize" Grid.Column="2" Text="12" FontSize="12" Foreground="#7A7067" VerticalAlignment="Center"/>
                </Grid>

                <!-- 字体 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="字体" FontSize="13" Foreground="#7A7067" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ComboFont" Grid.Column="1" Width="200" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                </Grid>

                <!-- 配色方案 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="配色方案" FontSize="13" Foreground="#7A7067" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ComboScheme" Grid.Column="1" Width="200" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                </Grid>

                <!-- Section 2: 终端 -->
                <TextBlock Text="终端" FontSize="16" FontWeight="SemiBold" Foreground="#2C2521" Margin="0,16,0,12"/>

                <!-- 亚克力效果 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="亚克力效果" FontSize="13" Foreground="#7A7067" VerticalAlignment="Center"/>
                    <CheckBox x:Name="ChkAcrylic" Grid.Column="1" IsChecked="True" VerticalAlignment="Center"/>
                </Grid>

                <!-- 光标形状 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="光标形状" FontSize="13" Foreground="#7A7067" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ComboCursor" Grid.Column="1" Width="150" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                </Grid>

                <!-- 光标高度 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="光标高度" FontSize="13" Foreground="#7A7067" VerticalAlignment="Center"/>
                    <Slider x:Name="SliderCursorHeight" Grid.Column="1" Minimum="25" Maximum="100" Value="25" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TextCursorHeight" Grid.Column="2" Text="25" FontSize="12" Foreground="#7A7067" VerticalAlignment="Center"/>
                </Grid>

                <!-- Section 3: Oh My Posh -->
                <TextBlock Text="Oh My Posh" FontSize="16" FontWeight="SemiBold" Foreground="#2C2521" Margin="0,16,0,12"/>

                <!-- 主题 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="主题" FontSize="13" Foreground="#7A7067" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ComboTheme" Grid.Column="1" Width="200" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Row 1: Preview + Buttons -->
        <StackPanel Grid.Row="1" Margin="0,8,0,0">

            <TextBlock Text="实时预览" FontSize="13" FontWeight="SemiBold" Foreground="#2C2521" Margin="0,0,0,8"/>

            <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" ClipToBounds="True">
                <Canvas x:Name="PreviewCanvas" Width="560" Height="300" HorizontalAlignment="Left"/>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button x:Name="BtnApply" Content="应用更改" Background="#D97757" Foreground="White" Padding="24,8" BorderThickness="0" FontSize="13"/>
                <Button x:Name="BtnReset" Content="恢复默认" Background="#E0D8CC" Foreground="#2C2521" Padding="16,8" BorderThickness="0" FontSize="12" Margin="12,0,0,0"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>