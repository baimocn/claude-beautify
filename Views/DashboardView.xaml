<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F5F0E8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Summary Bar -->
        <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="SummaryTitle" Text="组件状态" FontSize="15" FontWeight="SemiBold" Foreground="#2C2521"/>
                    <TextBlock x:Name="SummarySubtitle" Text="检测中..." FontSize="12" Foreground="#7A7067" Margin="0,4,0,0"/>
                </StackPanel>

                <Button x:Name="BtnRefresh" Grid.Column="1" Content="刷新"
                        Background="#D97757" Foreground="White" Padding="16,6" BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- Row 1: Health Check Summary -->
        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="健康检查" FontSize="15" FontWeight="SemiBold" Foreground="#2C2521"/>
                        <Border x:Name="HealthOverallBadge" CornerRadius="10" Background="#E0E0E0" Padding="10,3" Margin="12,0,0,0">
                            <TextBlock x:Name="HealthOverallText" Text="未检测" FontSize="11" Foreground="#7A7067"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="HealthSubtitle" Text="点击运行健康检查..." FontSize="12" Foreground="#7A7067" Margin="0,4,0,0"/>
                </StackPanel>

                <Button x:Name="BtnHealthCheck" Grid.Column="1" Content="运行健康检查"
                        Background="#6B7AC4" Foreground="White" Padding="16,6" BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- Row 2: Health Check Detail (initially hidden) -->
        <Border x:Name="HealthDetailPanel" Grid.Row="2" Background="#FFFFFF" CornerRadius="8"
                BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="0,0,0,12"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="组件健康详情" FontSize="13" FontWeight="SemiBold" Foreground="#2C2521" Margin="0,0,0,8"/>

                <!-- Per-component health status chips -->
                <WrapPanel x:Name="HealthChipsPanel" Margin="0,0,0,8">
                    <!-- Dynamically populated -->
                </WrapPanel>

                <!-- Selected component detail -->
                <Border x:Name="HealthDetailBox" Background="#F9F6F2" CornerRadius="6" Padding="12" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock x:Name="HealthDetailTitle" Text="选择组件查看详情" FontSize="12" FontWeight="SemiBold" Foreground="#2C2521"/>
                        <TextBlock x:Name="HealthDetailContent" Text="" FontSize="11" Foreground="#5A5047" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Fix button row -->
                <StackPanel x:Name="HealthFixPanel" Orientation="Horizontal" Margin="0,10,0,0" Visibility="Collapsed">
                    <Button x:Name="BtnFixSelected" Content="一键修复选中问题"
                            Background="#D97757" Foreground="White" Padding="16,6" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 3: Cards Grid -->
        <WrapPanel Grid.Row="3" Margin="0,8">

            <!-- Card 1: Oh My Posh -->
            <Border x:Name="CardOhMyPosh" Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Oh My Posh" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                        <Border x:Name="StatusBadgeOhMyPosh" Grid.Column="1" CornerRadius="10" Background="#F5F5F5" Padding="10,3">
                            <TextBlock Text="未安装" FontSize="11" Foreground="#7A7067"/>
                        </Border>
                    </Grid>

                    <!-- Description -->
                    <TextBlock Grid.Row="1" Text="PowerShell 提示符主题引擎" FontSize="12" Foreground="#7A7067" TextWrapping="Wrap" Margin="0,8,0,0" VerticalAlignment="Top"/>

                    <!-- Footer -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="VersionOhMyPosh" Grid.Column="0" Text="" FontSize="11" Foreground="#7A7067"/>
                        <Button x:Name="BtnOhMyPosh" Grid.Column="1" Content="安装" Background="#5A8F5A" Foreground="White" Padding="12,4" BorderThickness="0" FontSize="11"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Card 2: Nerd Font -->
            <Border x:Name="CardNerdFont" Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Nerd Font" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                        <Border x:Name="StatusBadgeNerdFont" Grid.Column="1" CornerRadius="10" Background="#F5F5F5" Padding="10,3">
                            <TextBlock Text="未安装" FontSize="11" Foreground="#7A7067"/>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="带图标和连字的等宽字体" FontSize="12" Foreground="#7A7067" TextWrapping="Wrap" Margin="0,8,0,0" VerticalAlignment="Top"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="VersionNerdFont" Grid.Column="0" Text="" FontSize="11" Foreground="#7A7067"/>
                        <Button x:Name="BtnNerdFont" Grid.Column="1" Content="安装" Background="#5A8F5A" Foreground="White" Padding="12,4" BorderThickness="0" FontSize="11"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Card 3: Windows Terminal -->
            <Border x:Name="CardWinTerminal" Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Windows Terminal" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                        <Border x:Name="StatusBadgeWinTerminal" Grid.Column="1" CornerRadius="10" Background="#F5F5F5" Padding="10,3">
                            <TextBlock Text="未安装" FontSize="11" Foreground="#7A7067"/>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="现代终端，支持标签页和多配置" FontSize="12" Foreground="#7A7067" TextWrapping="Wrap" Margin="0,8,0,0" VerticalAlignment="Top"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="VersionWinTerminal" Grid.Column="0" Text="" FontSize="11" Foreground="#7A7067"/>
                        <Button x:Name="BtnWinTerminal" Grid.Column="1" Content="安装" Background="#5A8F5A" Foreground="White" Padding="12,4" BorderThickness="0" FontSize="11"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Card 4: Terminal Config -->
            <Border x:Name="CardWTConfig" Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="终端配置" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                        <Border x:Name="StatusBadgeWTConfig" Grid.Column="1" CornerRadius="10" Background="#F5F5F5" Padding="10,3">
                            <TextBlock Text="未安装" FontSize="11" Foreground="#7A7067"/>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="Tokyo Night 配色 + 亚克力透明" FontSize="12" Foreground="#7A7067" TextWrapping="Wrap" Margin="0,8,0,0" VerticalAlignment="Top"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="VersionWTConfig" Grid.Column="0" Text="" FontSize="11" Foreground="#7A7067"/>
                        <Button x:Name="BtnWTConfig" Grid.Column="1" Content="安装" Background="#5A8F5A" Foreground="White" Padding="12,4" BorderThickness="0" FontSize="11"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Card 5: PowerShell Profile -->
            <Border x:Name="CardPSProfile" Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PowerShell Profile" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                        <Border x:Name="StatusBadgePSProfile" Grid.Column="1" CornerRadius="10" Background="#F5F5F5" Padding="10,3">
                            <TextBlock Text="未安装" FontSize="11" Foreground="#7A7067"/>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="Oh My Posh 主题 + PSReadLine 增强" FontSize="12" Foreground="#7A7067" TextWrapping="Wrap" Margin="0,8,0,0" VerticalAlignment="Top"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="VersionPSProfile" Grid.Column="0" Text="" FontSize="11" Foreground="#7A7067"/>
                        <Button x:Name="BtnPSProfile" Grid.Column="1" Content="安装" Background="#5A8F5A" Foreground="White" Padding="12,4" BorderThickness="0" FontSize="11"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Card 6: Status Bar -->
            <Border x:Name="CardStatusLine" Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0D8CC" BorderThickness="1" Padding="16" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="状态栏" FontSize="14" FontWeight="SemiBold" Foreground="#2C2521"/>
                        <Border x:Name="StatusBadgeStatusLine" Grid.Column="1" CornerRadius="10" Background="#F5F5F5" Padding="10,3">
                            <TextBlock Text="未安装" FontSize="11" Foreground="#7A7067"/>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="Claude Code 上下文与 Token 监控" FontSize="12" Foreground="#7A7067" TextWrapping="Wrap" Margin="0,8,0,0" VerticalAlignment="Top"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="VersionStatusLine" Grid.Column="0" Text="" FontSize="11" Foreground="#7A7067"/>
                        <Button x:Name="BtnStatusLine" Grid.Column="1" Content="安装" Background="#5A8F5A" Foreground="White" Padding="12,4" BorderThickness="0" FontSize="11"/>
                    </Grid>
                </Grid>
            </Border>

        </WrapPanel>
    </Grid>
</UserControl>
